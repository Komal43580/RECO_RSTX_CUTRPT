            reco_web_functions.add_data_column(TO_CHAR(vn_TmpGPInvQty));
                 
          ELSIF oTheSheetColumnInfo(colctr).rptColTypeCode = 'DELIVEREDSHIP'
          THEN
            IF nCtrPartVals <= oThisPartVals.count
